{
  "name": "nova-dashboard-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "migrate": "knex migrate:latest --knexfile src/knexfile.js",
    "seed": "knex seed:run --knexfile src/knexfile.js",
    "setup": "knex migrate:latest --knexfile src/knexfile.js && knex seed:run --knexfile src/knexfile.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.0.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0"
  }
}
